# Auth.js v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-a-long-random-string

# ---- LOCAL Postgres (default install, no cloud needed) ----
# If you installed PostgreSQL locally with default user "postgres" and password "postgres":
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gra?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/gra?schema=public"

# ---- OR Supabase cloud (uncomment and fill instead) ----
# Pooled connection string (used by the app at runtime)
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection string (used by `prisma migrate` / `prisma db push`)
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Supabase project URL (public)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
# Service-role key (server-only, preferred). If blank, the app falls back to the
# publishable/anon key — which works as long as the storage bucket is "public".
SUPABASE_SERVICE_ROLE_KEY="replace-with-service-role-key"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="replace-with-publishable-key"
SUPABASE_STORAGE_BUCKET="ticket-images"

# Optional seed values for `npm run db:seed`
SEED_ADMIN_EMAIL="admin@g-ra.dev"
SEED_ADMIN_PASSWORD="admin1234"
SEED_ADMIN_NAME="Admin"

# NOTE: The three SUPABASE_* vars below are ONLY needed for the ticket image
# upload feature. The board, tickets, comments and history all work without them.
# For local testing without a Supabase account, leave them blank — image upload
# will simply return an error, everything else works. Alternatively you can use
# local filesystem storage by setting USE_LOCAL_STORAGE=1 (see LOCAL.md).
